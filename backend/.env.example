# ─── Server ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── Auth ─────────────────────────────────────────────────────
# CHANGE THIS to a long random string in production!
JWT_SECRET=change_me_to_a_long_random_secret_string

# ─── Company Info (shown on invoices / quotations) ─────────────
COMPANY_NAME=Lyra Enterprises
COMPANY_ADDRESS=123 Main Street
COMPANY_CITY=Chennai
COMPANY_GSTIN=
COMPANY_PHONE=+91-9876543210
COMPANY_EMAIL=contact@lyracore.com

# ─── SMTP (for sending quotation emails) ──────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=LyraCore <your_email@gmail.com>
